# === Database (Supabase) ===
SUPABASE_DB_URL=postgresql://postgres:[password]@[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_VOICE_BUCKET=voice-assets
SUPABASE_VIDEO_BUCKET=video-assets

# === ElevenLabs TTS (Traditional Mandarin) ===
ELEVENLABS_API_KEY=
# Anna Su (Trustworthy) - Taiwanese Mandarin female, warm trustworthy narration
ELEVENLABS_VOICE_ID=r6qgCCGI7RWKXCagm158
ELEVENLABS_TTS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_STABILITY=0.4
ELEVENLABS_VOICE_SIMILARITY_BOOST=0.8
ELEVENLABS_APPLY_TEXT_NORMALIZATION=true

# === LLM (Claude via AWS Bedrock) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
ANTHROPIC_MODEL=anthropic.claude-opus-4-6-v1

# === Content Script Tuning (Chinese characters, not English words) ===
CONTENT_SCRIPT_TARGET_SECONDS=35
CONTENT_SCRIPT_TARGET_WORDS=140
CONTENT_SCRIPT_MAX_WORDS_BUFFER=15
CONTENT_SCRIPT_MIN_WORDS=100
CONTENT_SCRIPT_MIN_FACTS=3
CONTENT_SCRIPT_MIN_SENTENCES=5
CONTENT_SCRIPT_MAX_SENTENCES=8
CONTENT_LANGUAGE=zh-TW

# === Pre-voice Quality Gate ===
PRE_VOICE_DESCRIPTION_MIN_WORDS=4
PRE_VOICE_METADATA_ENRICHMENT_ENABLED=true
PRE_VOICE_ALLOW_TITLE_ONLY_FALLBACK=true
PRE_VOICE_TITLE_ONLY_MIN_WORDS=6
PRE_VOICE_FAIL_SUPPRESS_AFTER=3
PRE_VOICE_FAIL_SUPPRESS_DAYS=7
ARTICLE_CONTEXT_MIN_WORDS=20
ARTICLE_CONTEXT_MAX_WORDS=220

# === Engagement & Cadence ===
ENGAGEMENT_SCORING_ENABLED=true
ENGAGEMENT_MIN_SCORE=0.55
ENGAGEMENT_FLOOR_SCORE=0.50
CADENCE_MIN_POSTS_PER_RUN=1
CONTENT_MIX_PROFILE=hard_news_culture

# === World Journal Ingest ===
WJ_BASE_URL=https://www.worldjournal.com
WJ_CATEGORY_PATHS=/wj/cate/breaking,/wj/cate/breaking/121006,/wj/cate/breaking/121103,/wj/cate/breaking/121099,/wj/cate/breaking/121102,/wj/cate/breaking/121010,/wj/cate/breaking/121098
FALLBACK_FEEDS_ENABLED=false
FALLBACK_FEEDS_WORLD_FIRST=false
FALLBACK_FEEDS_MAX_POSTS=10
FALLBACK_FEED_URLS=
FALLBACK_MIN_JOBS_PER_RUN=1
TOPIC_BLOCKLIST_ENABLED=true
TOPIC_BLOCK_TERMS=廣告,贊助,工商,訂閱,促銷
SOURCE_DOMAIN_BLOCKLIST=
MAX_POSTS_PER_RUN=25
TOP_HEADLINES_PER_RUN=3
REQUEST_TIMEOUT_SECONDS=20
PERSONA_KEY=default

# === Publishing ===
PUBLISH_ENABLED=false
PUBLISH_PLATFORMS=metricool
PUBLISH_MAX_RETRIES=3
PUBLISH_MAX_JOBS_PER_RUN=3
PUBLISH_CLAIM_STALE_IN_PROGRESS_MINUTES=45
PUBLISH_ENFORCE_COMPLIANCE=true
ALLOW_DUPLICATE_LINK_REPOST=false

# === Metricool ===
METRICOOL_PUBLISH_ENABLED=false
METRICOOL_USER_TOKEN=
METRICOOL_API_URL=https://app.metricool.com/api
METRICOOL_USER_ID=
METRICOOL_BLOG_ID=
METRICOOL_TARGET_PLATFORMS=tiktok,instagram,youtube
METRICOOL_REVIEW_REQUIRED=false
METRICOOL_ANALYTICS_ENABLED=false
METRICOOL_ANALYTICS_LOOKBACK_DAYS=7
METRICOOL_ANALYTICS_FETCH_LIMIT=100

# === Discord Review Bot ===
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
DISCORD_REVIEW_CHANNEL_ID=
DISCORD_POLL_SECONDS=60
DISCORD_ALLOW_ALL_MEMBERS=true

# === Video Rendering (Remotion Fish Lipsync) ===
ENABLE_VIDEO_RENDER=true
REMOTION_PROJECT_DIR=pipeline/video_templates/fish_lipsync
FISH_MOUTH_FRAMES_DIR=pipeline/video_templates/fish_lipsync/public/mouth
FISH_BACKGROUND_IMAGE_PATH=pipeline/video_templates/fish_lipsync/public/background.png
VIDEO_SENSITIVITY=0.15
VIDEO_FREQ_START=1
VIDEO_FREQ_END=40
VIDEO_FISH_X=0
VIDEO_FISH_Y=14.3
VIDEO_FISH_SCALE=70
VIDEO_BG_X=0
VIDEO_BG_Y=0
VIDEO_BG_SCALE=100
VIDEO_POST_IMAGE_Y=-24
VIDEO_POST_IMAGE_SCALE=62
VIDEO_SHOW_DEBUG=false
VIDEO_INTRO_DURATION_SECONDS=2.0
VIDEO_INTRO_MUSIC_PATH=
VIDEO_INTRO_MUSIC_VOLUME=0.5
VIDEO_OUTRO_AUDIO_PATH=pipeline/video_templates/fish_lipsync/public/audio/breaking_news_outro.wav
VIDEO_OUTRO_VOLUME=1.0
VIDEO_TITLE_TICKER_SPEED=120
VIDEO_BROWSER_EXECUTABLE=
VIDEO_NPM_EXECUTABLE=
VIDEO_NPX_EXECUTABLE=
VIDEO_RENDER_CONCURRENCY=0
VIDEO_CODEC=h264
VIDEO_CRF=18
VIDEO_PIXEL_FORMAT=yuv420p
VIDEO_BITRATE=8M
VIDEO_AUDIO_BITRATE=192k

# === Captions (tuned for CJK) ===
VIDEO_CAPTION_Y=8
VIDEO_CAPTIONS_ENABLED=true
VIDEO_CAPTION_WORDS_PER_LINE=4
VIDEO_CAPTION_OFFSET_SECONDS=0
VIDEO_CAPTION_ALIGNMENT_ENABLED=true
VIDEO_CAPTION_ALIGNMENT_PROVIDER=elevenlabs
VIDEO_CAPTION_PAUSE_GAP_SECONDS=0.42
VIDEO_CAPTION_MAX_CUE_DURATION_SECONDS=2.0
VIDEO_CAPTION_MIN_CUE_DURATION_SECONDS=0.35
VIDEO_CAPTION_MAX_WORDS_PER_CUE=4
VIDEO_CAPTION_MIN_ALIGNMENT_COVERAGE=0.5
VIDEO_MEDIA_MAX_IMAGES=3
VIDEO_MEDIA_DISPLAY_SECONDS=2.5
VIDEO_REQUIRE_IMAGE_MEDIA=true

# === Media Quality Gate ===
MEDIA_QUALITY_GATE_ENABLED=true
MEDIA_QUALITY_MAX_CANDIDATES=8
MEDIA_QUALITY_MIN_IMAGE_WIDTH=640
MEDIA_QUALITY_MIN_IMAGE_HEIGHT=640
MEDIA_QUALITY_MIN_IMAGE_BYTES=20000
MEDIA_QUALITY_MIN_ASPECT_RATIO=0.5
MEDIA_QUALITY_MAX_ASPECT_RATIO=2.2
MEDIA_QUALITY_MIN_ENTROPY=4.0
MEDIA_QUALITY_MIN_SHARPNESS=25.0
MEDIA_QUALITY_REQUIRE_LLM_PASS=true
MEDIA_QUALITY_LLM_MODEL=anthropic.claude-opus-4-6-v1
MEDIA_QUALITY_LLM_MIN_QUALITY_SCORE=0.45
MEDIA_QUALITY_LLM_MIN_RELEVANCE_SCORE=0.5
MEDIA_QUALITY_MIN_COMPOSITE_SCORE=0.50
MEDIA_QUALITY_HEURISTIC_WEIGHT=0.45
MEDIA_QUALITY_LLM_WEIGHT=0.55
MEDIA_QUALITY_ASPECT_RATIO_PENALTY=0.32
MEDIA_QUALITY_LLM_ASSESSMENT_RETRIES=2
MEDIA_QUALITY_ALLOW_LLM_FAILURE_FALLBACK=true
MEDIA_QUALITY_LLM_FAILURE_HEURISTIC_MIN_SCORE=0.72

# === Thumbnail Generation ===
THUMBNAIL_GENERATION_ENABLED=true
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-nano-banana-pro
GEMINI_IMAGE_FALLBACK_MODEL=gemini-2.5-flash-image-preview
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_CX=
